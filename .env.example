# ──────────────────────────────────────────────────────────────────────────
# ATLAS — environment configuration (copy to .env)
# ──────────────────────────────────────────────────────────────────────────

# Runtime
APP_NAME=atlas
ENV=development                       # development | staging | production
LOG_LEVEL=INFO                        # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# HTTP
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Bridge WebSocket server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9000
BRIDGE_AUTH_TOKEN=change-me-bridge-token
BRIDGE_HEARTBEAT_TIMEOUT_SECONDS=30
BRIDGE_RECONNECT_GRACE_SECONDS=10

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://atlas:atlas@localhost:5432/atlas
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=20

# Redis (cache + pubsub + Celery broker)
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# LLM Assistant (hybrid: local + remote)
LLM_PROVIDER=openai                   # openai | anthropic | vllm | ollama | none
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30

# Telemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
PROMETHEUS_METRICS_PORT=9101

# Notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
TELEGRAM_BOT_TOKEN=
DISCORD_WEBHOOK_URL=
