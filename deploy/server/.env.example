# ─── ATLAS Production Environment Template ───────────────────────────────────
# Copy this to /opt/atlas/.env on your server and fill in all CHANGE_ME values.
# This file is NOT committed to git — it stays on the server only.
# Permissions should be: chmod 600 .env

# Injected automatically by GitHub Actions on each deploy — do not set manually
IMAGE_TAG=latest

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=atlas
ENV=production
LOG_LEVEL=INFO
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING_MIN_32_CHARS

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://app.atlas.example.com

# ─── MT5 Bridge ──────────────────────────────────────────────────────────────
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=9000
BRIDGE_AUTH_TOKEN=CHANGE_ME_BRIDGE_AUTH_TOKEN
BRIDGE_HEARTBEAT_TIMEOUT_SECONDS=30

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=atlas
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=atlas
DATABASE_URL=postgresql+asyncpg://atlas:CHANGE_ME_DB_PASSWORD@postgres:5432/atlas

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── AI / LLM (optional) ─────────────────────────────────────────────────────
LLM_PROVIDER=none
# LLM_API_KEY=sk-...

# ─── Observability ────────────────────────────────────────────────────────────
PROMETHEUS_METRICS_PORT=9101
GRAFANA_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD
# GRAFANA_URL=https://grafana.atlas.example.com

# ─── Notifications (optional) ────────────────────────────────────────────────
# TELEGRAM_BOT_TOKEN=
# DISCORD_WEBHOOK_URL=
